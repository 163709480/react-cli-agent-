{
  "name": "react-cli-agent",
  "version": "0.2.0",
  "private": false,
  "description": "Local terminal ReAct agent with OpenAI-compatible LLM, file sandbox, and tamper-proof audit log. AGPL-3.0.",
  "license": "AGPL-3.0",
  "author": "react-cli-agent contributors",
  "type": "module",
  "bin": {
    "react-cli-agent": "./dist/cli.js"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "tsx src/cli.tsx",
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "push:github": "bash scripts/push-to-github.sh"
  },
  "dependencies": {
    "@inkjs/ui": "^2.0.0",
    "chalk": "^5.3.0",
    "fast-glob": "^3.3.2",
    "gpt-tokenizer": "^2.5.0",
    "ink": "^5.0.1",
    "ink-text-input": "^6.0.0",
    "openai": "^4.55.0",
    "react": "^18.3.1",
    "uuid": "^10.0.0",
    "zod": "^3.23.8",
    "zod-to-json-schema": "^3.23.2"
  },
  "devDependencies": {
    "@types/node": "^22.5.0",
    "@types/react": "^18.3.5",
    "@types/uuid": "^10.0.0",
    "ink-testing-library": "^4.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.5.4",
    "vitest": "^2.1.1"
  }
}
